VERSION ""

NS_ :

BS_:

BU_: EngineECU TransmissionECU ABSECU AirbagECU ADASCamera BodyControl InstrumentCluster ParkingSensors Infotainment GatewayECU OBDII

BO_ 16 CrashDetection: 4 AirbagECU
 SG_ CrashSeverity  : 0|4@1+  (1,0)    [0|15]    ""   GatewayECU
 SG_ CrashZone      : 4|4@1+  (1,0)    [0|15]    ""   GatewayECU
 SG_ DeployCommand  : 8|8@1+  (1,0)    [0|255]   ""   GatewayECU
 SG_ CrashTimestamp : 16|16@1+ (1,0)   [0|65535] "ms" GatewayECU

BO_ 160 WheelSpeed: 8 ABSECU
 SG_ WheelSpeedFL : 0|16@1+  (0.01,0) [0|300] "kph" GatewayECU,EngineECU
 SG_ WheelSpeedFR : 16|16@1+ (0.01,0) [0|300] "kph" GatewayECU,EngineECU
 SG_ WheelSpeedRL : 32|16@1+ (0.01,0) [0|300] "kph" GatewayECU
 SG_ WheelSpeedRR : 48|16@1+ (0.01,0) [0|300] "kph" GatewayECU

BO_ 256 EngineStatus: 8 EngineECU
 SG_ EngineRPM     : 0|16@1+  (1,0)    [0|8000]  "RPM" InstrumentCluster,GatewayECU
 SG_ EngineTorque  : 16|16@1+ (0.1,-100) [-100|500] "Nm" GatewayECU,TransmissionECU
 SG_ EngineLoad    : 32|8@1+  (0.5,0)  [0|100]   "%"  GatewayECU
 SG_ EngineState   : 40|4@1+  (1,0)    [0|7]     ""   GatewayECU
 SG_ FuelCutoff    : 44|1@1+  (1,0)    [0|1]     ""   GatewayECU
 SG_ ChecksumEngine: 56|8@1+  (1,0)    [0|255]   ""   GatewayECU

BO_ 512 CoolantTemp: 2 EngineECU
 SG_ CoolantTemperature : 0|8@1+ (1,-40) [-40|215] "degC" InstrumentCluster,GatewayECU
 SG_ CoolantTempValid   : 8|1@1+ (1,0)   [0|1]     ""     GatewayECU

BO_ 2015 DiagRequest: 8 OBDII
 SG_ ServiceID : 0|8@1+  (1,0) [0|255] "" GatewayECU
 SG_ PID       : 8|8@1+  (1,0) [0|255] "" GatewayECU
 SG_ DiagData  : 16|48@1+ (1,0) [0|0]  "" GatewayECU

BO_ 176 BrakePressure: 4 ABSECU
 SG_ BrakePressureFront : 0|12@1+ (0.1,0) [0|250] "bar" GatewayECU,EngineECU
 SG_ BrakePressureRear  : 12|12@1+ (0.1,0) [0|250] "bar" GatewayECU
 SG_ ABSActive          : 24|1@1+ (1,0) [0|1] "" GatewayECU,InstrumentCluster
 SG_ BrakeValid         : 25|1@1+ (1,0) [0|1] "" GatewayECU

BO_ 192 AirbagStatus: 2 AirbagECU
 SG_ DriverAirbagArmed    : 0|1@1+ (1,0) [0|1] "" GatewayECU
 SG_ PassengerAirbagArmed : 1|1@1+ (1,0) [0|1] "" GatewayECU
 SG_ SeatbeltDriver       : 2|1@1+ (1,0) [0|1] "" InstrumentCluster,GatewayECU
 SG_ SeatbeltPassenger    : 3|1@1+ (1,0) [0|1] "" InstrumentCluster,GatewayECU
 SG_ AirbagFault          : 4|4@1+ (1,0) [0|15] "" InstrumentCluster,GatewayECU

BO_ 272 ThrottleStatus: 4 EngineECU
 SG_ ThrottlePosition   : 0|8@1+ (0.5,0) [0|100] "%" GatewayECU,TransmissionECU
 SG_ AccelPedalPosition : 8|8@1+ (0.5,0) [0|100] "%" GatewayECU
 SG_ ThrottleValid      : 16|1@1+ (1,0) [0|1] "" GatewayECU

BO_ 288 GearRequest: 4 TransmissionECU
 SG_ RequestedGear : 0|4@1+ (1,0) [0|8] "" GatewayECU,EngineECU
 SG_ ShiftMode     : 4|2@1+ (1,0) [0|3] "" GatewayECU

BO_ 304 GearStatus: 4 TransmissionECU
 SG_ CurrentGear : 0|4@1+ (1,0) [0|8] "" GatewayECU,InstrumentCluster
 SG_ GearEngaged : 4|1@1+ (1,0) [0|1] "" GatewayECU
 SG_ TransTemp   : 8|8@1+ (1,-40) [-40|215] "degC" GatewayECU

BO_ 528 OilPressure: 2 EngineECU
 SG_ OilPressure     : 0|8@1+ (0.1,0) [0|10] "bar" InstrumentCluster,GatewayECU
 SG_ OilPressureWarn : 8|1@1+ (1,0) [0|1] "" InstrumentCluster

BO_ 768 ADASObjects: 8 ADASCamera
 SG_ ObjectCount      : 0|4@1+ (1,0) [0|15] "" GatewayECU
 SG_ Object0Distance  : 4|12@1+ (0.1,0) [0|200] "m" GatewayECU
 SG_ Object0Velocity  : 16|12@1+ (0.1,-100) [-100|100] "kph" GatewayECU
 SG_ Object0Type      : 28|4@1+ (1,0) [0|15] "" GatewayECU
 SG_ LaneDeviation    : 32|12@1+ (0.01,-20) [-20|20] "cm" GatewayECU
 SG_ CollisionWarning : 44|2@1+ (1,0) [0|3] "" GatewayECU,InstrumentCluster

BO_ 1024 DoorStatus: 4 BodyControl
